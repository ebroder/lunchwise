{
  "name": "lunchwise",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run css && tsup --watch & npm run css:watch",
    "build": "tsup && npm run css",
    "start": "node dist/index.js",
    "css": "tailwindcss -i src/styles.css -o public/styles.css --minify",
    "css:watch": "tailwindcss -i src/styles.css -o public/styles.css --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@libsql/client": "^0.17.0",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "jose": "^6.1.3",
    "node-cron": "^4.2.1",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/node-cron": "^3.0.11",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
