{
  "name": "lunchwise",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev & vite dev",
    "build": "vite build && npm run css && node scripts/generate-spa-html.ts",
    "deploy": "npm run build && wrangler deploy",
    "css": "tailwindcss -i src/styles.css -o dist/client/styles.css --minify",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.4",
    "jose": "^6.1.3",
    "openapi-fetch": "^0.17.0",
    "preact": "^10.28.4",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/cli": "^4.2.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.0.0"
  }
}
