{
  "name": "lunchwise",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run css && wrangler dev & npm run css:watch",
    "build": "npm run css",
    "deploy": "npm run css && wrangler deploy",
    "css": "tailwindcss -i src/styles.css -o public/styles.css --minify",
    "css:watch": "tailwindcss -i src/styles.css -o public/styles.css --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "jose": "^6.1.3",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "@tailwindcss/cli": "^4.2.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.0.0"
  }
}
