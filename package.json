{
  "name": "lunchwise",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "wrangler dev & vite dev",
    "build": "vite build && npm run css && node scripts/generate-spa-html.ts",
    "deploy": "npm run build && wrangler deploy",
    "css": "tailwindcss -i src/styles.css -o dist/client/styles.css --minify",
    "lint": "oxlint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@sentry/cloudflare": "^10.49.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "jose": "^6.2.2",
    "openapi-fetch": "^0.17.0",
    "preact": "^10.29.1",
    "stemmer": "^2.0.1",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@cloudflare/workers-types": "^4.20260421.1",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/cli": "^4.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.61.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.0.18",
    "wrangler": "^4.84.0"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  }
}
